# AgentCore Git Ignore
#
# Keep this file tracked. Do not add /.gitignore here — remote clones would lose
# ignore rules (secrets, archives, runtime data) and git-sync could push them.

# Local archives / offline packs (never sync)
archives/
Archive/
archive/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
.venv/
venv/
env/
.smoke-temp/

# =============================================================================
# AgentCore operator runtime (local data / logs / secrets — never commit)
# Default state: .agentcore/  (projects, sync-progress, sync-usage, mcp fragment,
# optional sync.yaml override, install-state, probes).
# If you relocate AGENTCORE_SYNC_USAGE_LOG_DIR, keep it under .agentcore/, logs/,
# or a folder named sync-usage/ so these rules still apply.
# =============================================================================
.agentcore/

# Sync usage reports (default .agentcore/sync-usage/; also if relocated)
**/sync-usage/
sync-usage.jsonl
**/sync-usage.jsonl
*.sync-usage.jsonl

# Sync filter copy (operator-owned; template stays tracked)
agentcore.sync.yaml
agentcore.sync.yml
!agentcore.sync.yaml.example
!agentcore.sync.yml.example

# Node / Next.js
node_modules/
.next/
out/
dist/
build/
coverage/
.npm/
.pnpm-store/
.yarn/

# Environment and secrets (never commit real values)
.env
.env.local
**/.env
**/.env.local
.env.*
!**/.env.example
!.env.example
!**/*.example.env
*.pem
*.key
*.crt
*.p12
*.pfx
*.token
*.secret
secrets/
.local-secrets/
**/credentials.json
**/credentials.local.*

# git-sync (local-only tool + PAT + first-push msg + change notes — never commit)
scripts/git-sync.sh
**/git-sync.sh
scripts/.git-sync-first-push.msg
**/.git-sync-first-push.msg
scripts/.git-sync-changes/
**/.git-sync-changes/
**/.git-sync.local.env
**/.git-sync.local.env.*
**/git-sync.local.env
**/git-sync.local.env.*
**/.git-sync.credentials
**/git-sync.credentials
!**/git-sync.local.env.example

# Logs and runtime output
*.log
logs/
runtime/
tmp/
tmp/**
/tmp/
temp/
.cache/
.DS_Store
Thumbs.db
.pip-show.txt
.pip-*.txt

