# AgentCore Git Ignore
#
# Keep this file tracked. Do not add /.gitignore here — remote clones would lose
# ignore rules (secrets, archives, runtime data) and git-sync could push them.

# Local archives / offline packs (never sync)
archives/
Archive/
archive/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
.venv/
venv/
env/
.smoke-temp/
.agentcore/

# Node / Next.js
node_modules/
.next/
out/
dist/
build/
coverage/
.npm/
.pnpm-store/
.yarn/

# Environment and secrets
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.token
*.secret
secrets/
.local-secrets/
**/credentials.json
**/credentials.local.*

# git-sync (local-only tool + PAT + first-push msg + change notes — never commit)
scripts/git-sync.sh
**/git-sync.sh
scripts/.git-sync-first-push.msg
**/.git-sync-first-push.msg
scripts/.git-sync-changes/
**/.git-sync-changes/
**/.git-sync.local.env
**/.git-sync.local.env.*
**/git-sync.local.env
**/git-sync.local.env.*
**/.git-sync.credentials
**/git-sync.credentials
!**/git-sync.local.env.example

# Logs and runtime output
*.log
logs/
runtime/
tmp/
tmp/**
/tmp/
temp/
.cache/
.DS_Store
Thumbs.db
.pip-show.txt
.pip-*.txt

# Agent / IDE local wiring + full ai-toolstack (local tooling — never sync)
.cursor/
.cursorrules
**/.cursorrules
**/ponytail-stack-cursor.mdc
docs/agents/cursor-*.md
backend/integrations/agents/cursor/
backend/integrations/ides/cursor/
.agents/
.agent-runs/
.agent-sessions/
.agent-cache/
agent-runtime/
agent-workspaces/
agent_logs/
agent-memory-dumps/
project_docs/
.codex/
.mcp-memory
.mcp-memory/
ai-toolstack/
Ai-toolstack/
AI-Toolstack/

