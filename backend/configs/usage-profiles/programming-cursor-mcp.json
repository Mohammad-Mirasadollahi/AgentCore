{
  "profile_id": "programming-cursor-mcp",
  "version": "1.0.0",
  "title": "Programming with Cursor via MCP",
  "audience": "software-engineering",
  "description": "Configures AgentCore for software engineering teams that connect Cursor IDE through MCP to use memory, docs drift/write, code graph, tasks, and durable project writes.",
  "domain_pack": "default",
  "feature_profile": "default",
  "connectors": [
    {
      "id": "cursor-mcp",
      "type": "ide_mcp",
      "vendor": "cursor",
      "transport": "stdio",
      "protocol": "mcp"
    }
  ],
  "mcp": {
    "server_name": "agentcore-programming",
    "tools": [
      {
        "name": "agentcore_ping",
        "description": "Confirm MCP connectivity and return active usage profile metadata for this project.",
        "maps_to": "platform.ping",
        "input_schema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        }
      },
      {
        "name": "agentcore_get_effective_profile",
        "description": "Return the effective Usage Profile (domain pack, feature profile, connectors, MCP tools) for the scoped project.",
        "maps_to": "profile.effective",
        "input_schema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        }
      },
      {
        "name": "agentcore_memory_retrieve",
        "description": "Retrieve current-state memory hints for a programming task (maps to memory retrieval capability).",
        "maps_to": "memory.retrieve",
        "input_schema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Task or question text" },
            "include_history": { "type": "boolean", "default": false }
          },
          "required": ["query"],
          "additionalProperties": false
        }
      },
      {
        "name": "agentcore_code_graph_search",
        "description": "Search the code-knowledge graph for symbols relevant to a programming query.",
        "maps_to": "code_graph.search",
        "input_schema": {
          "type": "object",
          "properties": {
            "query": { "type": "string" },
            "top_k": { "type": "integer", "minimum": 1, "maximum": 50, "default": 5 }
          },
          "required": ["query"],
          "additionalProperties": false
        }
      },
      {
        "name": "agentcore_create_task",
        "description": "Create a durable Task record for follow-up engineering work.",
        "maps_to": "core_data.create_task",
        "input_schema": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "instructions": { "type": "string" }
          },
          "required": ["title"],
          "additionalProperties": false
        }
      },
      {
        "name": "agentcore_write",
        "description": "Write durable AgentCore records from Cursor: memory notes, tasks, activity, or decisions for the scoped project.",
        "maps_to": "platform.write",
        "input_schema": {
          "type": "object",
          "properties": {
            "resource": {
              "type": "string",
              "enum": ["memory", "task", "activity", "decision"],
              "description": "Which AgentCore resource to create"
            },
            "title": { "type": "string", "description": "Short title (memory/task/decision)" },
            "body": { "type": "string", "description": "Full text body (memory) or decision statement" },
            "instructions": { "type": "string", "description": "Task instructions (resource=task)" },
            "summary": { "type": "string", "description": "Activity action summary (resource=activity)" },
            "action_type": { "type": "string", "description": "Activity action type (resource=activity)", "default": "cursor_note" },
            "tags": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Optional tags for memory"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.9,
              "description": "Memory confidence 0..1"
            }
          },
          "required": ["resource"],
          "additionalProperties": false
        }
      },
      {
        "name": "agentcore_docs_drift_check",
        "description": "Request a documentation drift check for changed symbols (docs-sync capability).",
        "maps_to": "docs_sync.drift_check",
        "input_schema": {
          "type": "object",
          "properties": {
            "symbol": { "type": "string" },
            "file_path": { "type": "string" }
          },
          "required": ["symbol"],
          "additionalProperties": false
        }
      },
      {
        "name": "agentcore_docs_write",
        "description": "Documentation workflow from Cursor: validate frontmatter, index a doc note, or create a review draft for a symbol via docs-sync.",
        "maps_to": "docs_sync.write",
        "input_schema": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["validate", "note", "draft", "index"],
              "description": "validate=check frontmatter only; note/index=index a document; draft=create documentation draft for a symbol"
            },
            "title": { "type": "string" },
            "body": { "type": "string", "description": "Markdown body" },
            "symbol": { "type": "string", "description": "Symbol path for draft/note linking (e.g. auth.hash_password)" },
            "file_path": { "type": "string", "description": "Source file path for the symbol" },
            "path": { "type": "string", "description": "Logical docs path for note/index (e.g. docs/modules/auth.md)" },
            "owner": { "type": "string", "description": "Frontmatter owner (default mcp-gateway)" },
            "doc_id": { "type": "string", "description": "Optional stable doc_id" },
            "status": {
              "type": "string",
              "enum": ["draft", "active", "deprecated", "archived"],
              "default": "draft"
            },
            "frontmatter": {
              "type": "object",
              "description": "Optional full frontmatter object (validate/index). When set, overrides generated fields."
            }
          },
          "required": ["mode"],
          "additionalProperties": false
        }
      },
      {
        "name": "agentcore_docs_status",
        "description": "Return documentation coverage and missing-doc gaps for the scoped project.",
        "maps_to": "docs_sync.status",
        "input_schema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        }
      }
    ]
  },
  "defaults": {
    "isolation": "strict",
    "ide": "cursor"
  }
}
