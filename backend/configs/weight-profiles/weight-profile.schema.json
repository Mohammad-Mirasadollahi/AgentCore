{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcore.local/schemas/weight-profile.schema.json",
  "title": "AgentCore WeightProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "version",
    "owner",
    "status",
    "feature_weights",
    "thresholds"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "version": { "type": "integer", "minimum": 1 },
    "title": { "type": "string" },
    "owner": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "retired"]
    },
    "domain": { "type": "string" },
    "task_type": { "type": "string" },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "feature_weights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_weight",
        "episodic_weight",
        "working_weight",
        "evidence_weight",
        "recency_weight"
      ],
      "properties": {
        "semantic_weight": { "type": "number", "minimum": 0 },
        "episodic_weight": { "type": "number", "minimum": 0 },
        "working_weight": { "type": "number", "minimum": 0 },
        "evidence_weight": { "type": "number", "minimum": 0 },
        "recency_weight": { "type": "number", "minimum": 0 },
        "current_state_boost": { "type": "number", "minimum": 0 },
        "episodic_penalty": { "type": "number", "minimum": 0 }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_relevance_score", "context_token_budget"],
      "properties": {
        "min_relevance_score": { "type": "number" },
        "faq_min_observations": { "type": "integer", "minimum": 0 },
        "faq_min_evidence": { "type": "integer", "minimum": 0 },
        "context_token_budget": { "type": "integer", "minimum": 1 },
        "curiosity_min_observations": { "type": "integer", "minimum": 0 },
        "documentation_draft_min_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "documentation_task_min_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "retention_overrides": {
      "type": "object",
      "additionalProperties": true
    },
    "approved_by": { "type": "string" },
    "approved_at": { "type": "string" },
    "change_reason": { "type": "string" }
  }
}
