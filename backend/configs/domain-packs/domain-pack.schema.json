{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcore.local/schemas/domain-pack.schema.json",
  "title": "AgentCore DomainPack",
  "type": "object",
  "additionalProperties": false,
  "required": ["pack_id", "version", "title", "default_feature_profile"],
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([.-][A-Za-z0-9.-]+)?$"
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "workflows": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "default_feature_profile": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "default_rule_packs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "default_memory_profile": { "type": "string", "minLength": 1 },
    "vocabulary": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "security_constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "suggestions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rule_suggestions": { "type": "boolean" },
        "auto_activate_low_risk_rules": { "type": "boolean" }
      }
    }
  }
}
