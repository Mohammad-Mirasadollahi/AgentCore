# PostgreSQL URL for code-graph-service persistence (schema: code_graph).
# Default store backend is postgres. Set AGENTCORE_CODE_GRAPH_STORE=neo4j to use Neo4j.
AGENTCORE_CODE_GRAPH_STORE=postgres
AGENTCORE_CODE_GRAPH_DATABASE_URL=postgresql://agentcore:agentcore@127.0.0.1:5432/agentcore

# Neo4j structural store (optional; required when AGENTCORE_CODE_GRAPH_STORE=neo4j).
AGENTCORE_NEO4J_URI=bolt://127.0.0.1:32287
AGENTCORE_NEO4J_USER=neo4j
AGENTCORE_NEO4J_PASSWORD=replace-with-a-local-secret
AGENTCORE_NEO4J_DATABASE=neo4j
