# Service listen port
# -------------------
# AGENTCORE_CODE_GRAPH_PORT
#   HTTP port for code-graph-service (uvicorn). Port-profile default: 32140
#   Change → clients and health checks must use the new port; conflict if already bound.
AGENTCORE_CODE_GRAPH_PORT=32140

# PostgreSQL / structural store
# -----------------------------
# AGENTCORE_CODE_GRAPH_STORE
#   Selects the structural graph backend for code-graph-service.
#   Allowed: neo4j | postgres
#   Default in product: neo4j
#   Change to postgres → Neo4j is unused for symbols/edges; use for rollback/parity only.
#   Change to neo4j → symbols/edges live in Neo4j (requires NEO4J_* below).
AGENTCORE_CODE_GRAPH_STORE=neo4j

# AGENTCORE_CODE_GRAPH_DATABASE_URL
#   PostgreSQL URL for: (1) store=postgres structural data, (2) always recommended with
#   store=neo4j for pgvector symbol_embeddings + outbox mirror to code_graph.outbox.
#   Empty with neo4j → no pgvector index upsert and no Postgres outbox mirror (relay blind).
#   Invalid scheme → service startup fails.
AGENTCORE_CODE_GRAPH_DATABASE_URL=postgresql://agentcore:agentcore@127.0.0.1:32232/agentcore

# Neo4j structural store (required when AGENTCORE_CODE_GRAPH_STORE=neo4j)
# ---------------------------------------------------------------------
# AGENTCORE_NEO4J_URI
#   Bolt URI. Default in code if unset: bolt://127.0.0.1:32287 (port profile).
#   Wrong host/port → live ingest/parity fail; unit tests with fakes unaffected.
AGENTCORE_NEO4J_URI=bolt://127.0.0.1:32287

# AGENTCORE_NEO4J_USER
#   Neo4j username. Default: neo4j
AGENTCORE_NEO4J_USER=neo4j

# AGENTCORE_NEO4J_PASSWORD
#   Neo4j password. Required when store=neo4j. Empty → startup RuntimeError.
#   Also enables MCP auto graph_mode=neo4j when set to a non-placeholder value.
AGENTCORE_NEO4J_PASSWORD=replace-with-a-local-secret

# AGENTCORE_NEO4J_DATABASE
#   Neo4j database name. Default: neo4j
AGENTCORE_NEO4J_DATABASE=neo4j

# AGENTCORE_NEO4J_GDS_ENABLED
#   Opt-in to Neo4j Graph Data Science *Community* procedures for optional
#   degree ranking (gds.degree). Default: true (on).
#   false → never call GDS; always use Cypher degree fallback.
#   GDS Community is free but concurrency-limited to 4 CPU cores (no Enterprise key).
#   Communities (Leiden/Louvain) never use GDS regardless of this flag.
AGENTCORE_NEO4J_GDS_ENABLED=true

# AGENTCORE_NEO4J_GDS_CONCURRENCY
#   Threads for gds.degree when GDS is enabled. Default / hard max: 4
#   (Neo4j GDS Community Edition limit). Values above 4 are clamped to 4.
AGENTCORE_NEO4J_GDS_CONCURRENCY=4

# AGENTCORE_NEO4J_IMAGE
#   Docker image for Compose Neo4j service (not read by Python app code).
#   Default in compose.yaml: neo4j:5.26-community
#   Change to a patch-pinned tag (e.g. neo4j:5.26.4-community) for production reproducibility.
#   Wrong/unavailable image → Compose Neo4j fails to start; service Bolt URI then unreachable.
# AGENTCORE_NEO4J_IMAGE=neo4j:5.26-community

# MCP gateway graph wiring (mcp-gateway-service)
# ---------------------------------------------
# AGENTCORE_MCP_GRAPH_MODE
#   memory | postgres | neo4j. Empty → auto: neo4j when a real NEO4J_PASSWORD is set.
# AGENTCORE_MCP_GRAPH_MODE=
# AGENTCORE_MCP_GRAPH_SEED
#   true (default) seeds a tiny demo file only for memory/postgres graph modes.
#   Neo4j never receives the toy seed.
# AGENTCORE_MCP_GRAPH_SEED=false

# LiteLLM gateway — full reference:
#   docs/13-technology-stack-and-platform-decisions/12-litellm-environment-configuration.md
#   ADR: docs/13-technology-stack-and-platform-decisions/09-litellm-llm-gateway.md
# -----------------------------------------------------------------------------------------

# AGENTCORE_LITELLM_ENABLED
#   Master switch for the LiteLLM gateway adapter.
#   true  → complete/embed/docs-via-LLM paths may call LiteLLM (subject to other flags).
#   false → gateway.complete/embed raise; docs/embeddings fall back to heuristic/stub.
AGENTCORE_LITELLM_ENABLED=true

# AGENTCORE_LITELLM_HOST
#   Host used only when building the *auto* Base URL (no API_BASE override).
#   Change to another hostname → auto Base URL becomes http://{HOST}:{PORT}.
AGENTCORE_LITELLM_HOST=127.0.0.1

# AGENTCORE_LITELLM_PORT
#   Port for *auto* Base URL. Port-profile default: 32400 (not LiteLLM's upstream 4000).
#   Change → auto Base URL port changes; must match where your LiteLLM proxy listens.
AGENTCORE_LITELLM_PORT=32400

# AGENTCORE_LITELLM_API_BASE
#   Optional Base URL *override*. Empty → auto http://{HOST}:{PORT}.
#   Set (e.g. http://10.0.0.5:4100) → that URL is used for all LiteLLM calls; auto ignored.
#   Also accepted alias when this is empty: LITELLM_API_BASE
# AGENTCORE_LITELLM_API_BASE=http://127.0.0.1:32400

# AGENTCORE_LITELLM_API_KEY
#   API key for LiteLLM proxy or OpenAI-compatible endpoint.
#   Fallback order if empty: LITELLM_API_KEY → OPENAI_API_KEY.
#   Empty with providers that need a key → upstream auth errors on complete/embed.
AGENTCORE_LITELLM_API_KEY=

# AGENTCORE_LITELLM_DEFAULT_MODEL
#   Default LiteLLM model alias when a task-specific MODEL_* var is empty.
#   Example: ollama/qwen2.5-coder | gpt-4o-mini | azure/<deployment>
#   Empty + no task override → docs/embed stay on heuristic/stub (allow_stub).
AGENTCORE_LITELLM_DEFAULT_MODEL=ollama/qwen2.5-coder

# AGENTCORE_LITELLM_TIMEOUT_SECONDS
#   Per-request timeout passed to LiteLLM (seconds). Default: 180
#   Lower → faster fail on hung providers; may abort long completions.
#   Higher → waits longer; can stall workers under RPM pressure.
AGENTCORE_LITELLM_TIMEOUT_SECONDS=180

# AGENTCORE_LITELLM_NUM_RETRIES
#   LiteLLM num_retries for transient failures. Default: 3
#   0 → no SDK retries (still may hit RPM wait). Higher → more load on flaky providers.
AGENTCORE_LITELLM_NUM_RETRIES=3

# AGENTCORE_LITELLM_RPM
#   Client-side max requests per rolling 60s window. Default: 30
#   Lower → more waiting between calls; protects quotas.
#   Higher → more throughput; risk of provider 429s.
AGENTCORE_LITELLM_RPM=30

# AGENTCORE_LITELLM_DROP_PARAMS
#   Sets litellm.drop_params. true → unsupported provider params dropped silently.
#   false → stricter; some models may error on extra kwargs (e.g. response_format).
AGENTCORE_LITELLM_DROP_PARAMS=true

# AGENTCORE_LITELLM_REASONING_ENABLED
#   When true, chat completions send OpenRouter-style extra_body:
#     "reasoning": {"enabled": true}
#   Required for some models (e.g. openai/gpt-oss-*:free on OpenRouter).
#   false (default) → no reasoning object (safer for models that reject it).
#   Per-call override: CompletionRequest.reasoning_enabled or API field reasoning_enabled.
AGENTCORE_LITELLM_REASONING_ENABLED=false

# AGENTCORE_LITELLM_REASONING_EFFORT
#   Optional effort when reasoning is enabled (provider-specific: low|medium|high|…).
#   Empty → only {"enabled": true}. Set only if the model/docs require effort.
# AGENTCORE_LITELLM_REASONING_EFFORT=

# AGENTCORE_LITELLM_RISK_LEVEL
#   Routing risk for ModelRoutingProfile: low | medium | high. Default: low
#   Higher risk → stricter allow_stub (less silent fallback) and larger max_tokens for some tasks.
AGENTCORE_LITELLM_RISK_LEVEL=low

# AGENTCORE_LITELLM_PROFILE_ID
#   Label recorded on resolved routes (observability / config dump). Default: env-default
AGENTCORE_LITELLM_PROFILE_ID=env-default

# AGENTCORE_LITELLM_DOCS_ENABLED
#   When true, changed-symbol docs try LiteLLM (LlmBackedDocGenerator) then heuristic fallback.
#   false → always heuristic docs (no model calls for documentation).
AGENTCORE_LITELLM_DOCS_ENABLED=true

# AGENTCORE_LITELLM_EMBEDDINGS_ENABLED
#   When true AND local BGE is disabled, HybridEmbeddings calls LiteLLM and
#   projects vectors to AGENTCORE_EMBEDDING_DIMS for pgvector.
#   Prefer local BGE (below) for Stage-1 production embeddings.
AGENTCORE_LITELLM_EMBEDDINGS_ENABLED=false

# --- Local embeddings (BAAI/bge-large-en-v1.5, Stage-1 default) ---
# Cache lives under /opt so relocating the AgentCore tree does not delete models.
#
# AGENTCORE_EMBEDDING_PROVIDER
#   local_bge (default) | stub | litellm
AGENTCORE_EMBEDDING_PROVIDER=local_bge
#
# AGENTCORE_EMBEDDING_LOCAL_ENABLED
#   true (default) → load SentenceTransformer locally; false → stub or LiteLLM path.
AGENTCORE_EMBEDDING_LOCAL_ENABLED=true
#
# AGENTCORE_EMBEDDING_MODEL
#   Hugging Face id. Default: BAAI/bge-large-en-v1.5 (1024-d).
AGENTCORE_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
#
# AGENTCORE_EMBEDDING_CACHE_DIR
#   Root for HF + sentence-transformers caches (must be outside the app tree).
AGENTCORE_EMBEDDING_CACHE_DIR=/opt/agentcore-models
#
# AGENTCORE_EMBEDDING_DIMS
#   Must match pgvector column width (1024 for bge-large-en-v1.5).
AGENTCORE_EMBEDDING_DIMS=1024
#
# AGENTCORE_EMBEDDING_DEVICE
#   cpu (default) | cuda | mps
AGENTCORE_EMBEDDING_DEVICE=cpu

# AGENTCORE_EMBEDDING_PRELOAD
#   When true, load local BGE at process start (build_service) instead of lazy
#   load on first embed. Ops knob for cold-start demos (Phase F2).
AGENTCORE_EMBEDDING_PRELOAD=false

# AGENTCORE_LITELLM_MODEL_DOCS
#   Override model for task docs.generate. Empty → DEFAULT_MODEL.
AGENTCORE_LITELLM_MODEL_DOCS=

# AGENTCORE_LITELLM_MODEL_EMBED
#   Override model for task embed.symbol. Empty → DEFAULT_MODEL.
#   Use an embedding-capable alias (e.g. text-embedding-3-small) when EMBEDDINGS_ENABLED=true.
AGENTCORE_LITELLM_MODEL_EMBED=

# AGENTCORE_LITELLM_MODEL_JUDGE
#   Override model for task rules.judge (json_mode). Empty → DEFAULT_MODEL.
AGENTCORE_LITELLM_MODEL_JUDGE=

# AGENTCORE_LITELLM_MODEL_CODEGEN
#   Override model for task codegen.synthesize. Empty → DEFAULT_MODEL.
AGENTCORE_LITELLM_MODEL_CODEGEN=

# AGENTCORE_LITELLM_FALLBACK_MODELS
#   Comma/semicolon-separated LiteLLM aliases tried after primary fails.
#   Example: gpt-4o-mini,ollama/llama3.2
#   Empty → no fallback chain beyond primary.
AGENTCORE_LITELLM_FALLBACK_MODELS=

# Optional provider credentials (set only what you use)
# ----------------------------------------------------
# Discovery: GET /api/v1/llm/providers or: PYTHONPATH=backend/packages python -m llm_gateway providers
# OPENAI_API_KEY marks provider openai configured=true and may auth OpenAI models.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=
# OLLAMA_API_BASE=http://127.0.0.1:11434
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=
# LITELLM_API_BASE=   # alias for AGENTCORE_LITELLM_API_BASE when the latter is empty
# LITELLM_API_KEY=    # alias for AGENTCORE_LITELLM_API_KEY when the latter is empty
