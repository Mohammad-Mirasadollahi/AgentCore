AGENTCORE_POSTGRES_DATABASE=agentcore
AGENTCORE_POSTGRES_USER=agentcore
AGENTCORE_POSTGRES_PASSWORD=replace-with-a-local-secret
AGENTCORE_POSTGRES_PORT=32232
AGENTCORE_NEO4J_USER=neo4j
AGENTCORE_NEO4J_PASSWORD=replace-with-a-local-secret
AGENTCORE_NEO4J_BOLT_PORT=32287
AGENTCORE_NEO4J_HTTP_PORT=32474
