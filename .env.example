# AgentCore operator env (repo root)
# Copy to `.env` and edit. `agentcore init` also writes the scope keys below.
# NEVER commit `.env` — it is gitignored.

# --- Active scope (from agentcore init) ---
AGENTCORE_TENANT_ID=acme
AGENTCORE_WORKSPACE_ID=eng
# AGENTCORE_PROJECT_ID=myapp
# Absolute software roots for sync (colon-separated). Prefer: agentcore init --path …
# AGENTCORE_SOFTWARE_PATHS=/opt/MyApp

# --- Optional sync filters (comma-separated; or use agentcore.sync.yaml) ---
# AGENTCORE_SYNC_EXCLUDE_DIRS=docs,tests,fixtures
# AGENTCORE_SYNC_INCLUDE_PATHS=backend/services,backend/packages
# AGENTCORE_SYNC_INCLUDE_EXTENSIONS=.py,.ts,.tsx

# --- Optional embedding / graph CLI (local dogfood) ---
# AGENTCORE_EMBEDDING_PROVIDER=stub
# AGENTCORE_GRAPH_CLI_BACKEND=neo4j

# --- Sync usage reports (one JSON per run; folder FIFO ≤5 GiB) ---
# Keep this path under an ignored tree (.agentcore/… or logs/… or …/sync-usage/).
# AGENTCORE_SYNC_USAGE_LOG_DIR=.agentcore/sync-usage
# AGENTCORE_SYNC_USAGE_LOG_DIR_MAX_BYTES=5368709120

# Infra secrets for Compose live under:
#   backend/deployments/compose/.env.local
# (also gitignored; created by install.sh)
