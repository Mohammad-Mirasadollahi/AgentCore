# AgentCore operator env (repo root) — single source of truth
# Copy to `.env` and edit. `agentcore init` / `install.sh` create `.env` when missing.
# NEVER commit `.env` — it is gitignored.
# Normative contract:
#   docs/13-technology-stack-and-platform-decisions/12-litellm-environment-configuration.md
# CLI loads this file automatically (process env still wins).

# =============================================================================
# Active scope (from agentcore init)
# =============================================================================
AGENTCORE_TENANT_ID=acme
AGENTCORE_WORKSPACE_ID=eng
# AGENTCORE_PROJECT_ID=myapp
# Absolute software roots for sync (colon-separated). Prefer: agentcore init --path …
# AGENTCORE_SOFTWARE_PATHS=/opt/MyApp

# --- Optional sync filters (comma-separated; or use agentcore.sync.yaml) ---
# AGENTCORE_SYNC_EXCLUDE_DIRS=docs,tests,fixtures
# AGENTCORE_SYNC_INCLUDE_PATHS=backend/services,backend/packages
# AGENTCORE_SYNC_INCLUDE_EXTENSIONS=.py,.ts,.tsx

# --- Sync usage reports (one JSON per run; folder FIFO ≤5 GiB) ---
# Keep this path under an ignored tree (.agentcore/… or logs/… or …/sync-usage/).
# AGENTCORE_SYNC_USAGE_LOG_DIR=.agentcore/sync-usage
# AGENTCORE_SYNC_USAGE_LOG_DIR_MAX_BYTES=5368709120

# AGENTCORE_GRAPH_CLI_BACKEND
#   neo4j | postgres | memory — in-process graph CLI / sync backend hint.
# AGENTCORE_GRAPH_CLI_BACKEND=neo4j

# AGENTCORE_SYNC_CPU_PERCENT
#   Operator CPU budget for agentcore sync (auto | 1-100).
#   When set to N, derives file workers ≈ N% of CPU cores, local-embed
#   concurrency, and pins Torch/OMP to 1 thread (avoids RAM blow-ups).
#   Example: AGENTCORE_SYNC_CPU_PERCENT=25
# AGENTCORE_SYNC_CPU_PERCENT=auto
#
# AGENTCORE_SYNC_MAX_FILE_WORKERS
#   Advanced override: exact parallel file worker count.
#   When set to an integer, wins over AGENTCORE_SYNC_CPU_PERCENT.
#   Default/auto → min(cpu_count, AGENTCORE_LITELLM_RPM) when CPU percent is auto.
# AGENTCORE_SYNC_MAX_FILE_WORKERS=auto

# Infra secrets for Compose live under:
#   backend/deployments/compose/.env.local
# (also gitignored; created by install.sh)

# =============================================================================
# code-graph-service — listen port + structural store
# =============================================================================

# AGENTCORE_CODE_GRAPH_PORT — HTTP port (uvicorn). Port-profile default: 32140
AGENTCORE_CODE_GRAPH_PORT=32140

# AGENTCORE_CODE_GRAPH_STORE — neo4j | postgres (product default: neo4j)
AGENTCORE_CODE_GRAPH_STORE=neo4j

# PostgreSQL URL for pgvector + outbox (and structural data when store=postgres)
AGENTCORE_CODE_GRAPH_DATABASE_URL=postgresql://agentcore:agentcore@127.0.0.1:32232/agentcore

# Neo4j (required when AGENTCORE_CODE_GRAPH_STORE=neo4j)
AGENTCORE_NEO4J_URI=bolt://127.0.0.1:32287
AGENTCORE_NEO4J_USER=neo4j
AGENTCORE_NEO4J_PASSWORD=replace-with-a-local-secret
AGENTCORE_NEO4J_DATABASE=neo4j
AGENTCORE_NEO4J_GDS_ENABLED=true
AGENTCORE_NEO4J_GDS_CONCURRENCY=4
# AGENTCORE_NEO4J_IMAGE=neo4j:5.26-community

# Feature 49 — optional local LSP edit session (IDE-semantic; never dual-writes CODE_REL)
# AGENTCORE_LSP_EDIT_SESSION=1
# AGENTCORE_LSP_CMD_PYTHON=pyright-langserver --stdio
# AGENTCORE_LSP_CMD_TYPESCRIPT=typescript-language-server --stdio
# AGENTCORE_LSP_CMD_JAVASCRIPT=typescript-language-server --stdio
# AGENTCORE_LSP_CMD_GO=gopls serve
# AGENTCORE_LSP_CMD_RUST=rust-analyzer

# MCP gateway graph wiring (mcp-gateway-service)
# AGENTCORE_MCP_GRAPH_MODE=   # memory | postgres | neo4j; empty → auto
# AGENTCORE_MCP_GRAPH_SEED=false

# =============================================================================
# LiteLLM gateway
# ADR: docs/13-technology-stack-and-platform-decisions/09-litellm-llm-gateway.md
# Routing: docs/13-technology-stack-and-platform-decisions/10-model-routing-profiles-with-litellm.md
# =============================================================================

AGENTCORE_LITELLM_ENABLED=true
AGENTCORE_LITELLM_HOST=127.0.0.1
AGENTCORE_LITELLM_PORT=32400
# Optional Base URL override (empty → auto http://{HOST}:{PORT})
# AGENTCORE_LITELLM_API_BASE=http://127.0.0.1:32400
# Direct OpenRouter example:
# AGENTCORE_LITELLM_API_BASE=https://openrouter.ai/api/v1

# Key fallback order if empty: LITELLM_API_KEY → OPENROUTER_API_KEY → OPENAI_API_KEY
AGENTCORE_LITELLM_API_KEY=

AGENTCORE_LITELLM_DEFAULT_MODEL=ollama/qwen2.5-coder
# Verify: agentcore llm test
AGENTCORE_LITELLM_TIMEOUT_SECONDS=180
AGENTCORE_LITELLM_NUM_RETRIES=3
AGENTCORE_LITELLM_RPM=30
AGENTCORE_LITELLM_DROP_PARAMS=true
AGENTCORE_LITELLM_DEBUG=false

# OpenRouter-style reasoning (required for some models e.g. openai/gpt-oss-*:free)
AGENTCORE_LITELLM_REASONING_ENABLED=false
# AGENTCORE_LITELLM_REASONING_EFFORT=

AGENTCORE_LITELLM_RISK_LEVEL=low
AGENTCORE_LITELLM_PROFILE_ID=env-default
AGENTCORE_LITELLM_DOCS_ENABLED=true
AGENTCORE_LITELLM_EMBEDDINGS_ENABLED=false

# Per-task model overrides (empty → DEFAULT_MODEL)
AGENTCORE_LITELLM_MODEL_DOCS=
AGENTCORE_LITELLM_MODEL_EMBED=
AGENTCORE_LITELLM_MODEL_JUDGE=
AGENTCORE_LITELLM_MODEL_CODEGEN=
# Comma/semicolon-separated fallbacks after primary fails
AGENTCORE_LITELLM_FALLBACK_MODELS=

# =============================================================================
# Local embeddings (BAAI/bge-large-en-v1.5, Stage-1 default)
# =============================================================================
AGENTCORE_EMBEDDING_PROVIDER=local_bge
AGENTCORE_EMBEDDING_LOCAL_ENABLED=true
AGENTCORE_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
AGENTCORE_EMBEDDING_CACHE_DIR=/opt/agentcore-models
AGENTCORE_EMBEDDING_DIMS=1024
AGENTCORE_EMBEDDING_DEVICE=cpu
AGENTCORE_EMBEDDING_PRELOAD=false

# =============================================================================
# Optional provider credentials (set only what you use)
# Discovery: PYTHONPATH=backend/packages python -m llm_gateway providers
# =============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=
# OLLAMA_API_BASE=http://127.0.0.1:11434
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=
# LITELLM_API_BASE=   # alias when AGENTCORE_LITELLM_API_BASE empty
# LITELLM_API_KEY=    # alias when AGENTCORE_LITELLM_API_KEY empty
